{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=taskmanager.db"
  },
  "Jwt": {
    "Secret": "CHANGE-ME-super-secret-development-signing-key-min-32-chars-long",
    "Issuer": "TaskManager",
    "Audience": "TaskManagerClient",
    "ExpiryMinutes": 120
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
